<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:elevation="0dp">

        <!-- Header Global -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="30dp"
            android:paddingBottom="0dp">
            <include layout="@layout/layout_header_global" />
        </FrameLayout>

        <RelativeLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/secondary_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/btnBack"
                android:text="Pago Seguro"
                android:textColor="@color/secondary_green"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Finaliza tu reserva"
                android:textColor="@color/text_dark_green"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cifrado SSL 256-bit — Transacción Protegida"
                android:textColor="@color/light_text"
                android:textSize="14sp" />

            <!-- Resumen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_summary_card"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_medical_cross"
                    app:tint="@color/primary_green"/>
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONSULTA MÉDICA"
                        android:textSize="10sp"
                        android:textColor="#94A3B8"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvEspecialidadPago"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pediatría"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/dark_slate"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPrecioPago"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$65.00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"/>
            </LinearLayout>

            <!-- Tarjeta decorativa -->
            <LinearLayout
                android:id="@+id/layoutPreviewCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="190dp"
                android:background="@drawable/bg_dark_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginTop="24dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivChipIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_chip"
                        android:layout_alignParentStart="true"/>
                    <ImageView
                        android:id="@+id/ivCardBrandIcon"
                        android:layout_width="46dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_star"
                        app:tint="#FFFFFF"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvCardNumberPreview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="••••  ••••  ••••  ••••"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="24dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TITULAR"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                        <TextView
                            android:id="@+id/tvCardHolderPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOMBRE APELLIDO"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EXPIRA"
                            android:textSize="10sp"
                            android:textColor="#94A3B8"/>
                        <TextView
                            android:id="@+id/tvCardExpiryPreview"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MM/AA"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Formulario Stripe -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DATOS DE TARJETA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#64748B"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

            <com.stripe.android.view.CardInputWidget
                android:id="@+id/cardInputWidget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"/>

            <!-- Botón Pagar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPagar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/primary_green"
                android:text="Pagar $65.00 de forma segura"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_shield"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_shield"
                    app:tint="#94A3B8"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PCI DSS Compliant • SSL 256-bit"
                    android:textSize="11sp"
                    android:textColor="#94A3B8"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
