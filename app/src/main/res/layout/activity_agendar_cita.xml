<?xml version="1.0" encoding="utf-8"?>
<!-- la parte del cap -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:elevation="0dp">

        <!-- Header Global -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="30dp"
            android:paddingBottom="0dp">
            <include layout="@layout/layout_header_global" />
        </FrameLayout>

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="@string/title_schedule_appointment"
            app:titleTextColor="@color/dark_slate" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/appBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/subtitle_schedule_appointment"
                android:textColor="@color/light_text"
                android:textSize="14sp" />

            <!-- 1. Especialidad -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/step_specialty"
                    android:textColor="@color/dark_slate"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/see_all"
                    android:textColor="@color/secondary_green"
                    android:textSize="14sp" />
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/pillCardio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_unselected"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/specialty_cardio"
                        android:textColor="@color/light_text"
                        app:drawableStartCompat="@drawable/ic_heart"
                        app:drawableTint="@color/light_text" />

                    <TextView
                        android:id="@+id/pillPediatria"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill_unselected"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/specialty_pediatrics"
                        android:textColor="@color/light_text"
                        app:drawableStartCompat="@drawable/ic_baby"
                        app:drawableTint="@color/light_text" />

                    <TextView
                        android:id="@+id/pillMedicina"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill_unselected"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/specialty_general"
                        android:textColor="@color/light_text"
                        app:drawableStartCompat="@drawable/ic_medical_cross"
                        app:drawableTint="@color/light_text" />

                    <TextView
                        android:id="@+id/pillGineco"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill_unselected"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/specialty_gyn"
                        android:textColor="@color/light_text"
                        app:drawableStartCompat="@drawable/ic_female_health"
                        app:drawableTint="@color/light_text" />

                    <TextView
                        android:id="@+id/pillNutricion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill_unselected"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/specialty_nutrition"
                        android:textColor="@color/light_text"
                        app:drawableStartCompat="@drawable/ic_medical_cross"
                        app:drawableTint="@color/light_text" />

                    <TextView
                        android:id="@+id/pillPsicologia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill_unselected"
                        android:drawablePadding="8dp"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:text="@string/specialty_psychology"
                        android:textColor="@color/light_text"
                        app:drawableStartCompat="@drawable/ic_person"
                        app:drawableTint="@color/light_text" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Placeholder Vacío -->
            <LinearLayout
                android:id="@+id/placeholderEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_medical_cross"
                    android:alpha="0.2"
                    app:tint="@color/primary_green" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Selecciona una especialidad médica\npara continuar con tu reserva."
                    android:textAlignment="center"
                    android:textColor="@color/light_text"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Detalle de Especialidad (Dinámico) -->
            <LinearLayout
                android:id="@+id/sectionEspecialidadDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#F0F0F0"
                    app:strokeWidth="1dp">

                    <TextView
                        android:id="@+id/tvEspecialidadDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:padding="12dp"
                        android:text="Descripción..."
                        android:textColor="@color/light_text"
                        android:textSize="14sp" />
                </com.google.android.material.card.MaterialCardView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/containerServiciosEspecialidad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 2. Selecciona Profesional -->
            <LinearLayout
                android:id="@+id/sectionProfessional"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/step_professional"
                    android:textColor="@color/dark_slate"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/doctorsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Dinámicamente cargaremos los doctores aquí -->
                </LinearLayout>
            </LinearLayout>

            <!-- 3. Fecha y Hora -->
            <LinearLayout
                android:id="@+id/sectionDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/step_date_time"
                    android:textColor="@color/dark_slate"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/calendarContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_white_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/current_month_year"
                            android:textColor="@color/dark_slate"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_arrow_forward"
                                android:rotation="180"
                                app:tint="@color/light_text" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="16dp"
                                android:src="@drawable/ic_arrow_forward"
                                app:tint="@color/light_text" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Simplified Calendar View for demo -->
                    <LinearLayout
                        android:id="@+id/datesContainerStatic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/dayMon"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/CalendarDay"
                            android:text="L\n25"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/dayTue"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/CalendarDay"
                            android:text="M\n26"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/dayWed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/CalendarDay"
                            android:text="X\n1"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/dayThu"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/CalendarDay"
                            android:text="J\n2"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/dayFri"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/CalendarDay"
                            android:text="V\n3"
                            android:background="@drawable/bg_pill_unselected"
                            android:clickable="true"
                            android:focusable="true"/>
                        <TextView
                            android:id="@+id/daySat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/CalendarDay"
                            android:text="S\n4"
                            android:clickable="true"
                            android:focusable="true" />
                        <TextView
                            android:id="@+id/daySun"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/CalendarDay"
                            android:text="D\n5"
                            android:alpha="0.5" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/datesContainerDynamic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/timeSlotsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_white_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/available_times"
                        android:textColor="@color/dark_slate"
                        android:textSize="14sp" />

                    <GridLayout
                        android:id="@+id/timesGridStatic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:columnCount="3">

                        <TextView
                            android:id="@+id/time0900"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TimeSlot"
                            android:text="09:00" />
                        <TextView
                            android:id="@+id/time1030"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TimeSlot"
                            android:text="10:30" />
                        <TextView
                            android:id="@+id/time1115"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TimeSlot"
                            android:text="11:15" />
                        <TextView
                            android:id="@+id/time1400"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TimeSlot"
                            android:text="14:00" />
                        <TextView
                            android:id="@+id/time1530"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TimeSlot"
                            android:text="15:30" />
                        <TextView
                            android:id="@+id/time1645"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TimeSlot"
                            android:text="16:45" />
                    </GridLayout>

                    <GridLayout
                        android:id="@+id/timesGridDynamic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:columnCount="3"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/estimated_duration"
                        android:textColor="@color/light_text"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 4. Resumen -->
            <LinearLayout
                android:id="@+id/sectionSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/step_summary"
                    android:textColor="@color/dark_slate"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_summary_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/SummaryRow">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_doctor"
                            android:textColor="@color/light_text" />
                        <TextView
                            android:id="@+id/summaryDoctor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/not_selected"
                            android:textColor="@color/dark_slate"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/SummaryRow">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_date"
                            android:textColor="@color/light_text" />
                        <TextView
                            android:id="@+id/summaryDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/not_selected_fem"
                            android:textColor="@color/dark_slate"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/SummaryRow">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_time"
                            android:textColor="@color/light_text" />
                        <TextView
                            android:id="@+id/summaryTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/not_selected_fem"
                            android:textColor="@color/dark_slate"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#E0E0E0" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_cost"
                            android:textColor="@color/light_text" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/consultation_price"
                            android:textColor="@color/primary_green"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/primary_green"
                    android:text="@string/btn_confirm_appointment"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_shield"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/cancellation_policy"
                    android:textColor="@color/light_text"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- la parte del cap -->
    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/layout_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
